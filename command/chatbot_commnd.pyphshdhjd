userbot_ids = set()
# Memori riwayat: userbot_histories[userbot_id][session_key] -> deque
userbot_histories = defaultdict(lambda: defaultdict(lambda: deque(maxlen=12)))

DEFAULT_ROLE_INSTRUCTION = (
    "kamu sedang membalas chat sebagai manusia di group chat "
    "balas dengan bahasa indonesia santai singkat natural dan nyambung dengan konteks "
    "jawaban cukup pendek satu kalimat sekitar 2 sampai 12 kata "
