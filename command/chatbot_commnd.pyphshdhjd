# --- INTEGRASI FINAL PADA STARTUP ---

async def finalize_maelyn_startup():
    """
    Langkah terakhir saat bot dinyalakan:
    Jalankan monitor kesehatan dan pembersih sampah memori.
    """
    for user_id in session.get_list():
        client = session.get_session(user_id)
        if client:
            # Jalankan monitor kesehatan di background
            asyncio.create_task(bot_health_monitor(client))
            # Jalankan pembersih cooldown dari Bagian 6
            asyncio.create_task(cooldown_cleaner())
            # Jalankan log stats cleaner (opsional)
            logger.info(f"Monitor kesehatan aktif untuk {user_id}")

    logger.info("--- SEMUA SISTEM MAELYN BERHASIL DIJALANKAN ---")
  
