# --- BAGIAN 21: HEALTH CHECK & AUTO-RESTART SYSTEM ---

async def check_api_health():
    """Mengecek apakah API Maelyn masih merespons atau sedang down."""
    session_http = await get_chat_session()
    try:
        # Test request ringan ke API
        async with session_http.get(API_URL, params={"text": "ping"}, timeout=5) as resp:
            return resp.status == 200
    except Exception:
        return False

async def bot_health_monitor(client):
    """
    Monitor kesehatan akun userbot secara berkala.
    Jika terputus, akan mencoba menyambungkan ulang.
    """
    current_ubot_id = client.me.id
    while True:
        try:
            # 1. Cek Koneksi Telegram
            if not client.is_connected:
                logger.warning(f"Akun {current_ubot_id} terputus! Mencoba login ulang...")
                await client.connect()
                if await client.start():
                    logger.info(f"Akun {current_ubot_id} berhasil tersambung kembali.")

            # 2. Cek Koneksi API Maelyn
            api_status = await check_api_health()
            if not api_status:
                logger.error("API Maelyn tidak merespons (Down). Menunggu 1 menit...")
                bot_stats["total_errors"] += 1
                await asyncio.sleep(60)
                continue

            # 3. Health check berhasil, tunggu sebelum cek lagi
            await asyncio.sleep(300) # Cek setiap 5 menit

        except errors.AccessTokenInvalid:
            logger.error(f"Sesi akun {current_ubot_id} expired! Segera ganti session file.")
            break
        except Exception as e:
            logger.error(f"Error pada health monitor: {e}")
            await asyncio.sleep(30)

